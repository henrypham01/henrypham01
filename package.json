{
  "name": "kioviet",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron:dev": "concurrently \"next dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run db:template && next build && electron-builder",
    "electron:build:win": "npm run db:template && next build && electron-builder --win --x64",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:seed:users": "npx tsx prisma/seed-users.ts",
    "db:push": "npx prisma db push --accept-data-loss",
    "db:studio": "npx prisma studio",
    "db:template": "npx tsx scripts/build-template-db.ts"
  },
  "build": {
    "appId": "com.kioviet.app",
    "productName": "KioViet",
    "directories": { "output": "dist" },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*",
      "**/*.node"
    ],
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "src/generated/prisma/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/@prisma/adapter-better-sqlite3/**/*",
      "node_modules/@prisma/client/**/*",
      "node_modules/wait-on/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "resources/template.db", "to": "template.db" },
      { "from": ".next/standalone", "to": "app/.next/standalone" },
      { "from": ".next/static", "to": "app/.next/static" },
      { "from": "public", "to": "app/public" }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "public/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "KioViet"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/logo.png"
    }
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@prisma/adapter-better-sqlite3": "^7.7.0",
    "@prisma/client": "^7.6.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "dotenv": "^17.4.1",
    "electron-serve": "^3.0.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.7",
    "next": "16.2.2",
    "next-intl": "^4.9.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
